{
  "appId": "com.dan.space",
  "appName": "Spacely",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "*.supabase.co",
      "*.supabase.in",
      "accounts.google.com",
      "*.googleusercontent.com",
      "discord.com",
      "*.discord.com",
      "discordapp.com",
      "*.discordapp.com",
      "joinspacely.com",
      "*.joinspacely.com"
    ]
  },
  "android": {
    "path": "android",
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#050510",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#050510",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "native",
      "resizeOnFullScreen": true,
      "style": "Dark"
    }
  }
}
