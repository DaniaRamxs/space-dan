# ==========================================
# Spacely Project - Optimized .gitignore
# React + Tailwind + Tauri + Android + Node.js + Colyseus
# ==========================================

# ==========================================
# Node.js Dependencies
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/
.yarn/
.npm/
.eslintcache

# ==========================================
# Frontend Build Outputs (React + Vite)
# ==========================================
dist/
dist-ssr/
build/
.vite/
*.local

# ==========================================
# Tauri / Rust Build Artifacts
# ==========================================
# Rust compiled artifacts (can be >1GB)
target/
**/target/
src-tauri/target/
frontend/src-tauri/target/

# Tauri generated files
src-tauri/.tauri/
frontend/src-tauri/.tauri/
src-tauri/gen/
frontend/src-tauri/gen/

# Cargo lock for libraries (keep for apps)
# Cargo.lock

# ==========================================
# Android Build Artifacts
# ==========================================
# Gradle files
.gradle/
frontend/android/.gradle/
android/.gradle/

# Android build outputs
frontend/android/build/
frontend/android/app/build/
frontend/android/app/src/main/assets/public/
android/build/
android/app/build/
*.apk
*.aab
*.ap_
*.dex

# Android Studio
.idea/
*.iml
local.properties

# ==========================================
# Environment Variables & Secrets
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env

# ==========================================
# Logs & Temporary Files
# ==========================================
logs/
*.log
*.log.*
.DS_Store
Thumbs.db

# ==========================================
# Editor & IDE Files
# ==========================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ==========================================
# Deployment & Platform Files
# ==========================================
.vercel/
.netlify/
.railway/

# ==========================================
# OS Files
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ==========================================
# Testing & Coverage
# ==========================================
coverage/
.nyc_output/
*.lcov

# ==========================================
# Miscellaneous
# ==========================================
.cache/
.temp/
.tmp/
*.pid
*.seed
*.pid.lock
